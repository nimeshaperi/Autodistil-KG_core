# ============================================================================
# Graph Traverser Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# ============================================================================
# Neo4j Graph Database Configuration
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ============================================================================
# LLM Provider Configuration
# ============================================================================

# OpenAI / ChatGPT
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=  # Optional: Custom endpoint URL

# Google Gemini (Vertex AI)
GEMINI_PROJECT_ID=your-gcp-project-id
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-pro
GEMINI_CREDENTIALS_PATH=/path/to/your/service-account-key.json

# Anthropic Claude
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
CLAUDE_MODEL=claude-3-opus-20240229

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# vLLM (Local LLM)
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=mistral-7b

# ============================================================================
# Redis State Storage Configuration
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=  # Optional: Leave empty if no password
REDIS_KEY_PREFIX=graph_traverser:

# ============================================================================
# Traversal Configuration (Optional - can be set in code)
# ============================================================================
# TRAVERSAL_STRATEGY=bfs  # Options: bfs, dfs, random, semantic
# TRAVERSAL_MAX_NODES=100
# TRAVERSAL_MAX_DEPTH=3

# ============================================================================
# Dataset Generation Configuration (Optional - can be set in code)
# ============================================================================
# DATASET_OUTPUT_PATH=output/dataset.jsonl
# DATASET_OUTPUT_FORMAT=jsonl  # Options: jsonl, json
# DATASET_SYSTEM_MESSAGE=You are a helpful assistant that explains knowledge graph nodes.

# ============================================================================
# Logging Configuration (Optional)
# ============================================================================
# LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
